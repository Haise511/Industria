# PostgreSQL — Railway подставляет автоматически
DATABASE_URL="postgresql://user:password@localhost:5432/industria"

# Telegram bot
BOT_TOKEN="your-telegram-bot-token"
BOT_USERNAME="IndustriaBot"

# Публичный URL этого сервера (нужен для регистрации webhook)
SERVER_URL="https://industria-production-83f3.up.railway.app"

# Секретный путь webhook — Telegram будет слать апдейты на /bot/<это значение>
BOT_SECRET_PATH="tg-webhook"

# JWT
JWT_SECRET="change-me-to-a-long-random-secret"

# Сервер
PORT=3000

# CORS (можно * в dev, или конкретный домен в prod)
FRONTEND_URL="http://localhost:5173"

# URL фронтенда для кнопки бота — должен быть https://
APP_URL="https://your-app.vercel.app"
