# PostgreSQL connection string
# Railway автоматически подставит DATABASE_URL при деплое
DATABASE_URL="postgresql://user:password@localhost:5432/industria"

# Токен бота от @BotFather
BOT_TOKEN="your-telegram-bot-token"

# Секрет для подписи JWT (любая длинная случайная строка)
JWT_SECRET="change-me-to-a-long-random-secret"

# Порт сервера (Railway подставляет автоматически)
PORT=3000

# URL фронтенда для CORS (например https://industria.vercel.app)
FRONTEND_URL="http://localhost:5173"
