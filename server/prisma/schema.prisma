generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  artist
  customer
  studio
  composer
}

enum ContractType {
  contract
  cash
}

enum OrderMode {
  normal
  toi
}

enum OrderStatus {
  open
  awaiting_date
  today
  awaiting_confirmation
  awaiting_rating
  completed
  cancelled
  // closed — устаревшее значение, оставлено для обратной совместимости со старыми записями.
  closed
}

enum ResponseStatus {
  waiting
  accepted
  rejected
  // withdrawn — исполнитель отозвал отклик до ответа автора (пока статус waiting).
  withdrawn
}

model User {
  id         Int      @id @default(autoincrement())
  telegramId BigInt   @unique
  name       String
  username   String?
  role       Role
  city       String?
  bio        String?
  avatarUrl  String?
  // Rating is the running arithmetic mean of received Review.stars,
  // updated in /orders/:id/review. ratingCount is the number of reviews
  // that contributed. Display tier is derived (see toUserRating in api.ts):
  //   <3 reviews -> "Новый",  3-9 -> max(rating, 3.0),  10+ -> rating.
  rating     Float    @default(0)
  ratingCount Int     @default(0)
  verified   Boolean  @default(false)
  contract   Boolean  @default(false)
  language   String   @default("ru")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orders          Order[]
  responses       Response[]
  notifications   Notification[]
  reviewsGiven    Review[]       @relation("ReviewsGiven")
  reviewsReceived Review[]       @relation("ReviewsReceived")
}

model Order {
  id          Int          @id @default(autoincrement())
  orderNumber Int          @unique @default(autoincrement())
  author      User         @relation(fields: [authorId], references: [id])
  authorId    Int
  price       Int
  description String
  city        String?
  date        String?
  contract    ContractType @default(cash)
  mode        OrderMode    @default(normal)
  status      OrderStatus  @default(open)
  editFrozen  Boolean      @default(false)
  cancelReason String?
  confirmedAt DateTime?
  confirmedByAuthor   Boolean @default(false)
  confirmedByExecutor Boolean @default(false)
  acceptedResponseId  Int?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  responses Response[]
  reviews   Review[]
}

model Response {
  id          Int            @id @default(autoincrement())
  order       Order          @relation(fields: [orderId], references: [id])
  orderId     Int
  user        User           @relation(fields: [userId], references: [id])
  userId      Int
  date        String?
  comment     String?
  status      ResponseStatus @default(waiting)
  // Время отзыва отклика — пока остаётся в БД для аудита.
  // status='withdrawn' + withdrawnAt устанавливаются вместе.
  withdrawnAt DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@unique([orderId, userId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Один отзыв на сторону по каждому заказу. Когда обе стороны оставили
// отзыв, /orders/:id/review переводит заказ в completed.
model Review {
  id         Int      @id @default(autoincrement())
  order      Order    @relation(fields: [orderId], references: [id])
  orderId    Int
  fromUser   User     @relation("ReviewsGiven", fields: [fromUserId], references: [id])
  fromUserId Int
  toUser     User     @relation("ReviewsReceived", fields: [toUserId], references: [id])
  toUserId   Int
  stars      Int      // 1..5, валидация на стороне эндпоинта
  text       String?
  createdAt  DateTime @default(now())

  @@unique([orderId, fromUserId])
}
